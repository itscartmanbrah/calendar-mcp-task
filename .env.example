# Microsoft Graph — Calendar & Tasks MCP (workshop@burrowsjewellers.com.au)
# Entra app: PUBLIC client, device-code flow. No client secret is stored.

GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=

# Default timezone for events/tasks (IANA name). Mildura (VIC) = Eastern time.
GRAPH_DEFAULT_TIMEZONE=Australia/Melbourne
# Default phone-reminder lead time, in minutes, for events
GRAPH_DEFAULT_REMINDER_MINUTES=30
# Microsoft To Do list that tasks land in
GRAPH_TODO_LIST_NAME=Burrows Ops

# Token storage backend: 'postgres' (default; mirrors the dashboard's xero_tokens
# pattern, in the same burrows_jewellers DB) or 'file' (handy for local-first dev).
GRAPH_TOKEN_STORE=postgres
# Only used when GRAPH_TOKEN_STORE=file:
# GRAPH_TOKEN_FILE=./.graph-token.json

# Postgres — reuses the dashboard's burrows_jewellers DB for a graph_tokens table.
PGUSER=postgres
PGPASSWORD=
PGHOST=localhost
PGPORT=5432
PGDATABASE=burrows_jewellers

# --- HTTP transport (only for `npm run start:http`, the shared multi-client mode) ---
# Lets any Claude client connect by URL instead of stdio. Run behind nginx/TLS.
MCP_HTTP_PORT=4100
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PATH=/mcp/calendar
# Shared bearer secret clients must send (Authorization: Bearer ...). REQUIRED in prod.
MCP_AUTH_TOKEN=
